# ─── Care & Child AAC — Backend Environment ───────────────
# Copy this file to .env and fill in your credentials.
#
# Get SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY from:
#   https://supabase.com/dashboard → Settings → API
#
# ⚠️  Generate a strong API_KEY to protect the backend endpoints:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# ALLOWED_ORIGINS: comma-separated list of allowed CORS origins.
#   For production, set to your actual frontend domain(s).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

API_KEY=
ALLOWED_ORIGINS=*
